# Remittances (Remita) — environment configuration
# Copy to .env.local for development, or set these as Vercel project env vars.

# ── API ──────────────────────────────────────────────────────────
# Points to the debita NestJS API. In development use local; in Vercel set it to the dev stack.
# Local:     http://localhost:3000
# Dev stack: https://api.dev.debita.io
# The /api path is appended automatically in lib/api/client.ts
NEXT_PUBLIC_API_URL=https://api.dev.debita.io

# ── Auth0 ────────────────────────────────────────────────────────
# Same Auth0 tenant as the debita backend (tokens are shared).
NEXT_PUBLIC_AUTH0_DOMAIN=debita.eu.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=debita-api
# Must be a whitelisted callback in the Auth0 SPA app. For production use https://remita.io
NEXT_PUBLIC_AUTH0_REDIRECT_URI=http://localhost:3002

# ── Feature flags ────────────────────────────────────────────────
# Allow the user to pre-type the deposit amount (off for SEPA MVP, reference-only deposits).
NEXT_PUBLIC_DEPOSIT_AMOUNT_ENABLED=false

# Mock/design mode: run the UI with fixtures and no API (see lib/mocks/mockData.ts).
NEXT_PUBLIC_DESIGN_MODE=false
